{
  "name": "lcov_gh_badges",
  "description": "A GitHub Action for creating markdown embeddable badges directory from an LCOV .dat file.",
  "version": "1.0.0",
  "type": "module",
  "author": "Ryan McGuinness",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/rrmcguinness/lcov_gh_badges/issues"
  },
  "homepage": "https://github.com/rrmcguinness/lcov_gh_badges#readme",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "directories": {
    "lib": "lib",
    "test": "__test__"
  },
  "files": [
    "lib",
    "!.DS_Store"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -Rf ./lib && rm -Rf ./dist",
    "lint": "eslint .",
    "build": "tsc --declarationMap false",
    "prepare": "npm run build && ncc build lib/index.js -o dist --license LICENSE -m",
    "test": "NODE_OPTIONS='--import tsx' mocha __test__/**/*.ts",
    "tsc": "tsc",
    "all": "npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rrmcguinness/lcov_gh_badges.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript",
    "lcov",
    "Badge",
    "Dynamic"
  ],
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/http-client": "^4.0.0",
    "@tsconfig/node16": "^1.0.3",
    "@types/node": "^18.11.18",
    "@types/sprintf-js": "^1.1.2",
    "diff": "^8.0.3",
    "eslint": "^8.32.0",
    "npm": "^12.0.1",
    "serialize-javascript": "^7.0.4",
    "sprintf-js": "^1.1.2",
    "typescript": "^4.9.4",
    "undici": "^7.28.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.4",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@testdeck/mocha": "^0.3.3",
    "@types/mocha": "^10.0.1",
    "@vercel/ncc": "^0.38.4",
    "chai": "^4.3.7",
    "esbuild": "^0.28.1",
    "mocha": "^11.1.0",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22.x"
  }
}

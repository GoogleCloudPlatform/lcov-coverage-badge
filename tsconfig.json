{
  "extends": "@tsconfig/node16/tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "target": "ES2022",
    "esModuleInterop": true,
    "module": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "moduleResolution": "NodeNext",
    "sourceMap": false
  },
  "include": [
    "./src"
  ],
  "exclude": [
    "node_modules",
    "**/__test__/*",
    "**/__mocks__/*"
  ]
}